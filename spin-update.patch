+/**
+ * RouteFallback.css — Minimal spinner for lazy route chunks.
+ * Honors reduced-motion by dropping the spin animation.
+ */
+.route-fallback {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  justify-content: center;
+  gap: var(--space-3);
+  min-height: 60vh;
+  padding: var(--space-6);
+  color: var(--color-text-secondary);
+}
+
+.route-fallback__glyph {
+  font-size: 2.5rem;
+  display: inline-block;
+  animation: route-fallback-spin 1.8s linear infinite;
+}
+
+.route-fallback__label {
+  font-size: var(--font-size-sm);
+  letter-spacing: 0.04em;
+  text-transform: uppercase;
+  opacity: 0.8;
+}
+
+@keyframes route-fallback-spin {
+  from {
+    transform: rotate(0deg);
+  }
+  to {
+    transform: rotate(360deg);
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .route-fallback__glyph {
+    animation: none;
+  }
+}
+
+html[data-reduced-motion='true'] .route-fallback__glyph {
+  animation: none;
+}
